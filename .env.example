# Deployer wallet private key (without 0x prefix)
DEPLOYER_PRIVATE_KEY=

# IPFS metadata URIs (upload metadata JSONs to IPFS first)
COMMON_URI=ipfs://QmCommonHash/metadata.json
RARE_URI=ipfs://QmRareHash/metadata.json
LEGENDARY_URI=ipfs://QmLegendaryHash/metadata.json

# Frontend environment variables (set in frontend/.env.local)
# NEXT_PUBLIC_NFT_ADDRESS=0x...
# NEXT_PUBLIC_MARKETPLACE_ADDRESS=0x...
# NEXT_PUBLIC_WC_PROJECT_ID=  (get from https://cloud.walletconnect.com)
